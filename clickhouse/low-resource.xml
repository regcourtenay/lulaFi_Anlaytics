<!-- Low-resource tuning for a single ClickHouse node on a Raspberry Pi 5.
     Production uses a managed/replicated cluster (SDD v1.1 §20.4). -->
<clickhouse>
    <!-- Cap server memory to ~60% of the Pi's RAM. -->
    <max_server_memory_usage_to_ram_ratio>0.6</max_server_memory_usage_to_ram_ratio>
    <!-- Small caches; POC data volume is modest. -->
    <mark_cache_size>268435456</mark_cache_size>
    <uncompressed_cache_size>0</uncompressed_cache_size>
    <max_concurrent_queries>16</max_concurrent_queries>
    <logger>
        <level>warning</level>
    </logger>
    <profiles>
        <default>
            <max_threads>4</max_threads>
            <max_memory_usage>1500000000</max_memory_usage>
            <max_bytes_before_external_group_by>536870912</max_bytes_before_external_group_by>
        </default>
    </profiles>
</clickhouse>
